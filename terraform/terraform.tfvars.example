# cp terraform.tfvars.example terraform.tfvars 후 값 채우기
# terraform.tfvars는 .gitignore에 포함되어 커밋되지 않습니다.

aws_region        = "ap-northeast-2"
ssh_allowed_cidr  = "YOUR_IP/32"   # 예: curl ifconfig.me 로 확인 후 /32 붙이기
web_allowed_cidr  = "0.0.0.0/0"    # 필요 시 본인 IP 등으로 제한

ssh_public_key_path  = "~/.ssh/id_rsa.pub"
ssh_private_key_path = "~/.ssh/id_rsa" # auto_deploy_backend(기본 true)가 SSH 접속에 사용

# Backend에 .env/vector_db/data 업로드 + deploy_backend.sh 실행까지 terraform apply가
# 자동으로 해줌 (기본값 true). 끄고 싶으면:
# auto_deploy_backend = false

backend_instance_type = "t3.medium"

git_repo_url = "https://github.com/hijun318-eng/law_project2.git"
git_branch   = "main"

# ── Ranker 배포 방식: "ec2" / "runpod" / "runpod_serverless" ──────
ranker_deployment = "ec2"

# ec2 모드일 때만 사용 (ranker_deployment = "ec2")
ranker_instance_type = "g4dn.2xlarge"

# runpod (Pod) 모드일 때만 사용 (ranker_deployment = "runpod")
# 아래 주석을 해제하고 값을 채우세요.
# runpod_api_key                       = "..."                              # https://www.runpod.io/console/user/settings
# runpod_ranker_image                  = "docker.io/<id>/law-ranker:latest" # docker/Dockerfile.ranker.gpu 미리 build & push 필요
# runpod_network_volume_data_center_id = "US-CA-2"                          # Network Volume + Pod가 배치될 데이터센터
# ranker_django_secret_key             = "..."                              # 임의의 긴 문자열
# ranker_api_key                       = "..."                              # backend .env의 RANKER_API_KEY와 동일한 값 (backend/ranker 공유 비밀키)

# runpod_serverless 모드일 때만 사용 (ranker_deployment = "runpod_serverless")
# Template/Endpoint 모두 terraform apply가 네이티브 리소스로 직접 생성/관리합니다
# (runpod_official provider). runpodctl CLI나 별도 환경변수 설정 불필요.
# runpod_api_key                       = "..."
# runpod_network_volume_data_center_id = "US-CA-2"
# runpod_serverless_workers_min        = 0
# runpod_serverless_workers_max        = 2

# runpod_serverless_worker = "infinity" (기본값) — RunPod 공식 이미지 그대로 사용, 이미지 빌드 불필요.
# reranker_model만 바꾸면 다른 HF reranker로도 전환 가능. Backend .env에는
# RANKER_BACKEND=runpod_infinity, RANKER_MODEL=<reranker_model 값>을 반드시 맞춰서 설정.
# reranker_model = "Dongjin-kr/ko-reranker"

# runpod_serverless_worker = "custom"으로 바꾸면 직접 빌드한 이미지를 씀 (아래 필요):
# runpod_serverless_worker = "custom"
# runpod_serverless_image  = "docker.io/<id>/law-ranker-serverless:latest"  # docker/Dockerfile.ranker.serverless 미리 build & push 필요

# ── AWS RDS / vector_db S3 백업 (기본 활성화, doc/rds-postgres-migration.md 대응) ──
# 둘 다 기본값 true. 끄고 싶으면 아래처럼 false로.
# enable_rds                 = false   # false면 Backend는 SQLite로 동작
# enable_vector_db_s3_backup = false   # false면 S3 버킷/IAM 인스턴스 프로필 자체를 안 만듦

# RDS 비밀번호를 직접 지정하고 싶으면 (비워두면 자동 생성됨):
# rds_master_password = "..."

# S3 버킷 생성 시 로컬 vector_db/를 자동으로 올리고 싶지 않으면:
# vector_db_s3_auto_upload = false   # 기본값 true — apply를 실행하는 머신에 aws cli 필요

# S3 버킷명을 직접 지정하고 싶으면 (비워두면 <project_name>-vector-db-<계정ID>로 자동 생성):
# vector_db_s3_bucket_name = "my-custom-bucket-name"

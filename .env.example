# OpenAI API 키
# https://openai.com/ko-KR/api/
OPENAI_API_KEY=your_openai_api_key

# LLM Provider 설정 (openai | local)
LLM_PROVIDER=openai

# Django 설정
DJANGO_SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# 네이버 뉴스 API 키
# https://developers.naver.com/main/
NAVER_CLIENT_ID=your_naver_client_id_key
NAVER_CLIENT_SECRET=your_naver_client_secret_key

# Ranker 서비스 URL
# RunPod Pod로 배포한 경우 예: https://<pod-id>-8001.proxy.runpod.net
RANKER_URL=http://localhost:8001
# RunPod 등 외부 네트워크에 ranker를 노출할 때만 설정 (내부망 전용이면 비워둠)
RANKER_API_KEY=

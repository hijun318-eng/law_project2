# OpenAI API 키
# https://openai.com/ko-KR/api/
OPENAI_API_KEY=your_openai_api_key

# LLM Provider 설정 (openai | local)
LLM_PROVIDER=openai

# 로컬 LLM 설정 (LLM_PROVIDER=local 시 적용)
LOCAL_LLM_BASE_URL=http://localhost:1234/v1
LOCAL_LLM_MODEL=qwen2.5-3b-instruct

# 로컬 임베딩 모델 (sentence-transformers)
LOCAL_EMBEDDING_MODEL=intfloat/multilingual-e5-small

# LLM 호출 타임아웃(초) / 재시도 횟수(지수 백오프)
LLM_TIMEOUT_SECONDS=30
LLM_MAX_RETRIES=3

# Django 설정
DJANGO_SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database
# Empty DATABASE_URL uses local SQLite.
# RDS PostgreSQL example:
# DATABASE_URL=postgresql://law_user:password@your-rds-endpoint.ap-northeast-2.rds.amazonaws.com:5432/law_project2
DATABASE_URL=
DB_CONN_MAX_AGE=600
DB_SSL_REQUIRE=False

# 네이버 뉴스 API 키
# https://developers.naver.com/main/
NAVER_CLIENT_ID=your_naver_client_id_key
NAVER_CLIENT_SECRET=your_naver_client_secret_key

# Ranker 서비스 URL — 실제로 호출할 엔드포인트 전체 경로를 그대로 적는다(코드에서 경로를 덧붙이지 않음)
# RunPod Pod로 배포한 경우 예: https://<pod-id>-8001.proxy.runpod.net/rerank/
# RunPod Serverless(runsync)를 쓰는 경우 예: https://api.runpod.ai/v2/<endpoint-id>/runsync
RANKER_URL=http://localhost:8001/rerank/
# RunPod 등 외부 네트워크에 ranker를 노출할 때만 설정 (내부망 전용이면 비워둠)
RANKER_API_KEY=
# 콜드 스타트 + 최대 30문서 배치 처리 시간을 감안한 여유값
RANKER_TIMEOUT_SECONDS=30

# RunPod Serverless일 때만 의미 있음 (RANKER_URL에 api.runpod.ai가 포함된 경우).
# custom          - apps/ranker/handler.py 기반 커스텀 이미지 (기본값)
# runpod_infinity - RunPod 공식 worker-infinity-embedding 이미지 (이미지 빌드 불필요, HF 모델 이름만 설정)
RANKER_BACKEND=custom
# runpod_infinity 사용 시 요청의 "model" 필드에 넣을 값. Endpoint의 MODEL_NAMES와 반드시 일치해야 함
RANKER_MODEL=Dongjin-kr/ko-reranker
